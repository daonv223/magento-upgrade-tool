{
    "name": "betanet/magento-upgrade-autofixer",
    "description": "Scanner + auto-fixer for Magento upgrade PHP 8.x issues",
    "type": "project",
    "authors": [
        {
            "name": "daonv223",
            "email": "dao@betanet.co.il"
        }
    ],
    "require": {
        "php": "^8.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.4",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Betanet\\Autofixer\\": "src/"
        }
    },
    "license": ["proprietary"]
}
