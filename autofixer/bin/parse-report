#!/usr/bin/env python3
"""Parse a scan-problems JSON report and output module summary as JSON.

Usage:
    parse-report <report.json> [<report2.json> ...]

Output (JSON):
    [
        {"module": "Vendor_Module", "errors": 18, "types": ["return.missing", "property.notFound"]},
        ...
    ]
"""

import json
import sys


def parse_report(path):
    with open(path) as f:
        data = json.load(f)

    results = []
    files = data.get("files", {})
    if not isinstance(files, dict):
        return results
    for module_name, module_data in files.items():
        error_count = module_data.get("errors", 0)
        identifiers = set()
        for file_data in module_data.get("files", {}).values():
            for msg in file_data.get("messages", []):
                identifier = msg.get("identifier")
                if identifier:
                    identifiers.add(identifier)
        results.append({
            "module": module_name,
            "errors": error_count,
            "types": sorted(identifiers),
        })
    return results


def main():
    if len(sys.argv) < 2:
        print("Usage: parse-report <report.json> [<report2.json> ...]", file=sys.stderr)
        sys.exit(1)

    all_results = []
    for path in sys.argv[1:]:
        try:
            all_results.extend(parse_report(path))
        except (json.JSONDecodeError, FileNotFoundError, KeyError) as e:
            print(f"Error parsing {path}: {e}", file=sys.stderr)
            continue

    print(json.dumps(all_results, indent=2))


if __name__ == "__main__":
    main()
